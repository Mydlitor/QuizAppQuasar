{
  "name": "quiz-app-quasar",
  "version": "0.0.1",
  "description": "A Quasar Project",
  "productName": "Quiz App Quasar",
  "author": "Mydlitor <jakub.sputo@gmail.com>",
  "type": "module",
  "private": true,
  "scripts": {
    "lint": "eslint -c ./eslint.config.js \"./src*/**/*.{js,cjs,mjs,vue}\"",
    "format": "prettier --write \"**/*.{js,vue,css,scss,html,md,json}\" --ignore-path .gitignore",
    "test": "echo \"No test specified\" && exit 0",
    "dev": "quasar dev",
    "build": "quasar build",
    "postinstall": "quasar prepare && node node_modules/electron/install.js"
  },
  "dependencies": {
    "@quasar/extras": "^1.16.4",
    "quasar": "^2.16.0",
    "vue": "^3.5.22",
    "vue-router": "^5.0.3"
  },
  "devDependencies": {
    "@electron/packager": "^19.1.1",
    "@eslint/js": "^9.39.4",
    "@quasar/app-vite": "^2.6.2",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vueuse/core": "^14.3.0",
    "@vueuse/nuxt": "^14.3.0",
    "autoprefixer": "^10.4.27",
    "electron": "^42.3.3",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "vite-plugin-checker": "^0.12.0",
    "vue-eslint-parser": "^10.4.0"
  },
  "engines": {
    "node": "^28 || ^26 || ^24 || ^22.12",
    "npm": ">= 6.13.4",
    "yarn": ">= 1.21.1",
    "pnpm": ">= 10.0.0"
  },
  "allowScripts": {
    "@parcel/watcher@2.5.6": true,
    "esbuild@0.27.7": true,
    "esbuild@0.28.0": true
  }
}
